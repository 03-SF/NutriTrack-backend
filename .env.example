# ==================== SERVER CONFIGURATION ====================
PORT=5000
NODE_ENV=development
BASE_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173

# ==================== MONGODB ====================
MONGO_URI=mongodb://localhost:27017/nutritrack-ai
# Or use MongoDB Atlas:
# MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/nutritrack-ai?retryWrites=true&w=majority

# ==================== JWT AUTHENTICATION ====================
TOKEN_SECRET=your-super-secret-jwt-key-change-this-in-production
SESSION_SECRET=your-super-secret-session-key-change-this-in-production
TOKEN_EXPIRES_IN=1d

# ==================== GOOGLE OAUTH 2.0 ====================
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_OAUTH_REDIRECT=http://localhost:5000/api/auth/google/callback

# ==================== GOOGLE FIT API SCOPES ====================
# The following scopes will be requested:
# - fitness.activity.read (Steps, activities, calories)
# - fitness.body.read (Weight, height, BMI)
# - fitness.body.write (Update body metrics)
# - fitness.heart_rate.read (Heart rate data)
# - fitness.location.read (Distance/location)
# - fitness.nutrition.read (Nutrition data)
# - profile (User profile info)
# - email (User email)

# ==================== SYNC JOB CONFIGURATION ====================
# Sync job runs every 15 minutes by default (configured in syncJob.js)
# You can adjust the cron schedule in backend/src/syncJob.js
# Default: "*/15 * * * *" (every 15 minutes)
# Examples:
#   - Every 5 minutes: "*/5 * * * *"
#   - Every hour: "0 * * * *"
#   - Every 30 minutes: "*/30 * * * *"

# ==================== NOTES ====================
# 1. Create a Google Cloud Project: https://console.cloud.google.com/
# 2. Enable Google Fitness API
# 3. Create OAuth 2.0 credentials (Web application)
# 4. Add authorized redirect URIs:
#    - http://localhost:5000/api/auth/google/callback (development)
#    - https://yourdomain.com/api/auth/google/callback (production)
# 5. Copy Client ID and Client Secret to this file
# 6. Generate strong random strings for TOKEN_SECRET and SESSION_SECRET
